---
layout: base.njk
hero_title: Freshly Baked Cookies
hero_description: Small-batch cookies made with love. Order online for pickup or delivery.
---

<main>
  <section id="home" class="hero">
    <div class="container">
      <div class="row">
        <div class="col-12 col-lg-7 text-center text-lg-start hero-inner">
          <h1 class="display-5 fw-bold mb-3">{{ hero_title }}</h1>
          <p class="lead mb-4">{{ hero_description }}</p>
          <div class="hero-cta d-grid gap-2 d-sm-flex justify-content-sm-center justify-content-lg-start">
            <a class="btn btn-primary" href="#pricing">Select Your Package</a>
            <a class="btn btn-outline" href="#menu">Explore Menu</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section id="about" class="section alt">
    <div class="container">
      <h2 class="fs-2 fw-bold mb-3">About Cookie Nest</h2>
      <p>We are a family-run bakery focused on simple, high-quality ingredients and joyful flavors. We bake small batches to ensure every cookie tastes like home. From classic chocolate chip to exotic matcha, our cookies are made with love and the finest ingredients.</p>
    </div>
  </section>

  <section id="services" class="section">
    <div class="container">
      <h2 class="fs-2 fw-bold mb-3">Services</h2>
      <p>We offer pickup, local delivery, catering for events, corporate orders, and monthly subscription boxes. Delivery areas and catering quotes vary by location — please contact us for custom orders or large requests.</p>
    </div>
  </section>

  <section id="pricing" class="section pricing-section">
    <div class="container">
      <h2 class="fs-2 fw-bold mb-3">Pick Your Package</h2>
      <div class="pricing-options row g-4">
        <div class="col-12 col-sm-6 col-lg-3" style="min-width:0">
          <div class="pricing-card h-100" data-package="Single Cookie" data-count="1">
            <h3>Single Cookie</h3>
            <p class="price">$3</p>
            <p class="desc">Pick your favorite flavor</p>
            <button class="btn btn-select">Select</button>
          </div>
        </div>
        <div class="col-12 col-sm-6 col-lg-3" style="min-width:0">
          <div class="pricing-card h-100" data-package="Half Dozen" data-count="6">
            <h3>Half Dozen</h3>
            <p class="price">$16</p>
            <p class="desc">6 cookies (mix &amp; match)</p>
            <button class="btn btn-select">Select</button>
          </div>
        </div>
        <div class="col-12 col-sm-6 col-lg-3" style="min-width:0">
          <div class="pricing-card h-100" data-package="Dozen" data-count="12">
            <h3>Dozen</h3>
            <p class="price">$28</p>
            <p class="desc">12 cookies (mix &amp; match)</p>
            <button class="btn btn-select">Select</button>
          </div>
        </div>
        <div class="col-12 col-sm-6 col-lg-3" style="min-width:0">
          <div class="pricing-card h-100" data-package="Party Platter" data-count="24">
            <h3>Party Platter</h3>
            <p class="price">$55</p>
            <p class="desc">24 mixed assorted cookies</p>
            <button class="btn btn-select">Select</button>
          </div>
        </div>
      </div>
      <div class="order-summary" id="order-selector">
        <p class="selector-placeholder">Select a package above to customize your order.</p>
      </div>
    </div>
  </section>

