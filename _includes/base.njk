<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Cookie Nest — Fresh Bakes</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH" crossorigin="anonymous" />
    <link rel="stylesheet" href="styles/reset.css" />
    <link rel="stylesheet" href="styles/style.css" />
  </head>
  <body>
    <header class="site-header">
      <nav class="navbar navbar-expand-lg">
        <div class="container header-inner">
          <a class="logo navbar-brand" href="#home">Cookie Nest</a>
          <button class="nav-toggle navbar-toggler border-0" type="button" data-bs-toggle="collapse" data-bs-target="#mainNav" aria-controls="mainNav" aria-expanded="false" aria-label="Open navigation">☰</button>
          <div class="collapse navbar-collapse" id="mainNav">
            <nav class="site-nav navbar-nav ms-auto align-items-center">
              <a class="nav-link px-3 py-2" href="#services">Services</a>
              <a class="nav-link px-3 py-2" href="#about">About</a>
              <a class="nav-link px-3 py-2" href="#pricing">Pricing</a>
              <a class="nav-link px-3 py-2" href="#contact">Contact</a>
            </nav>
            <div class="d-grid d-lg-block mt-2 mt-lg-0 ms-lg-3">
              <a class="btn btn-primary" href="#contact">Order Now</a>
            </div>
          </div>
        </div>
      </nav>
    </header>

    <!-- Mobile-only welcome banner (hidden on desktop via d-lg-none) -->
    <div class="d-lg-none text-center py-2 px-3" style="background:linear-gradient(135deg,rgba(201,124,93,0.15),rgba(201,124,93,0.05));border-bottom:1px solid rgba(201,124,93,0.2);font-size:0.88rem;color:#a85e3f;font-weight:500;">
      Welcome to Cookie Nest — Order in just a few taps!
    </div>

    {{ content | safe }}

    <footer class="site-footer">
      <div class="footer-content">
        <div class="container">
          <div class="footer-grid row row-cols-1 row-cols-md-3 g-4">
            <div class="col footer-section">
              <h3>Cookie Nest</h3>
              <p>Handcrafted, small-batch cookies made with love and the finest ingredients.</p>
            </div>
            <div class="col footer-section">
              <h4>Quick Links</h4>
              <ul>
                <li><a href="#home">Home</a></li>
                <li><a href="#menu">Menu</a></li>
                <li><a href="#pricing">Pricing</a></li>
                <li><a href="#contact">Contact</a></li>
              </ul>
            </div>
            <div class="col footer-section">
              <h4>Contact</h4>
              <p>Email: <a href="mailto:orders@cookienest.example">orders@cookienest.example</a></p>
              <p>Phone: <a href="tel:+1234567890">+(373) 608269</a></p>
              <p>Hours: Mon-Fri 9am-6pm</p>
            </div>
          </div>
        </div>
      </div>
      <div class="footer-bottom">
        <div class="container">
          <p>&copy; <span id="year"></span> Cookie Nest. All rights reserved. | <a href="#">Privacy Policy</a> | <a href="#">Terms of Service</a></p>
        </div>
      </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script>
      // Prevent browser from restoring previous scroll position on refresh
      if ('scrollRestoration' in history) history.scrollRestoration = 'manual';

      document.addEventListener('DOMContentLoaded', function() {
        console.log('[CookieNest] JS running');
        console.log('[CookieNest] Bootstrap loaded:', typeof bootstrap !== 'undefined');
        var toggler = document.querySelector('.navbar-toggler');
        if (toggler) {
          toggler.addEventListener('click', function() {
            console.log('[CookieNest] Toggler clicked — #mainNav classes:', document.getElementById('mainNav').className);
          });
        } else {
          console.warn('[CookieNest] Toggler NOT found in DOM!');
        }

        // Auto-close collapsed navbar when a nav link is clicked (mobile only)
        // Prevents scroll fires while the open menu is still adding height to the sticky header
        var navCollapse = document.getElementById('mainNav');
        if (navCollapse) {
          navCollapse.querySelectorAll('a[href^="#"]').forEach(function(link) {
            link.addEventListener('click', function(e) {
              if (navCollapse.classList.contains('show')) {
                var target = this.getAttribute('href');
                e.preventDefault();
                var collapseInstance = bootstrap.Collapse.getInstance(navCollapse);
                collapseInstance.hide();
                navCollapse.addEventListener('hidden.bs.collapse', function scrollAfterClose() {
                  navCollapse.removeEventListener('hidden.bs.collapse', scrollAfterClose);
                  var el = document.querySelector(target);
                  if (el) el.scrollIntoView({ behavior: 'smooth', block: 'start' });
                });
              }
            });
          });
        }
      });

      document.getElementById('year').textContent = new Date().getFullYear();

      const FLAVORS = [
        'Semi-Sweet Chocolate Chunk',
        'Double Chocolate Bliss',
        'Biscoff Caramel Dream',
        'Red Velvet Romance',
        'Matcha Green Serenity',
        'Oreo Crunch Explosion',
        'Chocolate Mousse Luxury',
        'Pecan Pie Paradise'
      ];

      // Party Platter: this week's curated hottest flavors
      const PARTY_PICKS = [
        { name: 'Double Chocolate Bliss',  qty: 6 },
        { name: 'Biscoff Caramel Dream',   qty: 6 },
        { name: 'Matcha Green Serenity',   qty: 6 },
        { name: 'Oreo Crunch Explosion',   qty: 6 }
      ];

      const selectorEl = document.getElementById('order-selector');

      function renderSingle() {
        selectorEl.innerHTML =
          '<p class="selector-title">Choose your flavor</p>' +
          '<div class="flavor-radio-grid">' +
          FLAVORS.map(f =>
            '<label class="flavor-radio-option">' +
            '<input type="radio" name="single-flavor" value="' + f + '" />' +
            '<span>' + f + '</span>' +
            '</label>'
          ).join('') +
          '</div>' +
          '<p class="selector-confirm" id="single-confirm"></p>';

        selectorEl.querySelectorAll('input[name="single-flavor"]').forEach(function(input) {
          input.addEventListener('change', function() {
            document.getElementById('single-confirm').textContent = '\u2713 1 \xd7 ' + input.value + ' \u2014 ready to order!';
          });
        });
      }

      function renderMultiPicker(count) {
        var selections = {};
        FLAVORS.forEach(function(f) { selections[f] = 0; });

        function getTotal() {
          return FLAVORS.reduce(function(sum, f) { return sum + selections[f]; }, 0);
        }

        function render() {
          var remaining = count - getTotal();
          var done = getTotal() === count;
          selectorEl.innerHTML =
            '<p class="selector-title">Pick your ' + count + ' cookies ' +
            '<span class="selector-remaining">' + remaining + ' left to pick</span></p>' +
            '<div class="flavor-picker-grid">' +
            FLAVORS.map(function(f) {
              return '<div class="flavor-picker-item">' +
                '<span class="flavor-picker-name">' + f + '</span>' +
                '<div class="flavor-stepper">' +
                '<button class="step-btn minus" data-flavor="' + f + '"' + (selections[f] === 0 ? ' disabled' : '') + '>\u2212</button>' +
                '<span class="step-count">' + selections[f] + '</span>' +
                '<button class="step-btn plus" data-flavor="' + f + '"' + (remaining === 0 ? ' disabled' : '') + '>+</button>' +
                '</div></div>';
            }).join('') +
            '</div>' +
            (done ? '<p class="selector-confirm">\u2713 All ' + count + ' cookies selected \u2014 ready to order!</p>' : '');

          selectorEl.querySelectorAll('.step-btn').forEach(function(btn) {
            btn.addEventListener('click', function() {
              var f = btn.getAttribute('data-flavor');
              if (btn.classList.contains('plus') && getTotal() < count) selections[f]++;
              if (btn.classList.contains('minus') && selections[f] > 0) selections[f]--;
              render();
            });
          });
        }
        render();
      }

      function renderPartyPlatter() {
        selectorEl.innerHTML =
          '<p class="selector-title">This week\'s hottest flavors</p>' +
          '<p class="selector-subtitle">Your Party Platter is hand-curated by our bakers each week. Here\'s what\'s inside:</p>' +
          '<div class="party-picks">' +
          PARTY_PICKS.map(function(p) {
            return '<div class="party-pick-item"><span class="party-pick-name">' + p.name + '</span><span class="party-pick-qty">\xd7' + p.qty + '</span></div>';
          }).join('') +
          '</div>' +
          '<p class="selector-confirm">\u2713 24 cookies curated \u2014 ready to order!</p>';
      }

      var pricingCards = document.querySelectorAll('.pricing-card');
      pricingCards.forEach(function(card) {
        var btn = card.querySelector('.btn-select');
        btn.addEventListener('click', function() {
          pricingCards.forEach(function(c) { c.classList.remove('selected'); });
          card.classList.add('selected');
          var pkg = card.getAttribute('data-package');
          var count = parseInt(card.getAttribute('data-count'), 10);
          if (pkg === 'Single Cookie') renderSingle();
          else if (pkg === 'Half Dozen' || pkg === 'Dozen') renderMultiPicker(count);
          else renderPartyPlatter();
        });
      });
    </script>

    <!-- ── Floating mascot ── -->
    <style>
      #mascot-wrap {
        position: fixed;
        bottom: 90px;
        right: 20px;
        z-index: 2000;
        display: none;          /* hidden until JS shows it after delay */
        flex-direction: column;
        align-items: center;
        gap: 6px;
        cursor: pointer;
        -webkit-tap-highlight-color: transparent;
      }
      #mascot-wrap.mascot-visible {
        display: flex;
        animation: mascot-enter 0.5s cubic-bezier(0.34,1.56,0.64,1) both;
      }
      @keyframes mascot-enter {
        from { opacity:0; transform:translateY(40px) scale(0.6); }
        to   { opacity:1; transform:translateY(0)   scale(1);   }
      }
      #mascot-img {
        width: 72px;
        height: 72px;
        object-fit: contain;
        filter: drop-shadow(0 4px 10px rgba(0,0,0,0.18));
        animation: mascot-bounce 3s ease-in-out 1s infinite;
      }
      @keyframes mascot-bounce {
        0%,100% { transform: translateY(0); }
        40%      { transform: translateY(-10px); }
        60%      { transform: translateY(-6px); }
      }
      #mascot-tooltip {
        background: #fff;
        color: #a85e3f;
        font-size: 0.78rem;
        font-weight: 600;
        padding: 6px 10px;
        border-radius: 10px;
        border: 1.5px solid rgba(201,124,93,0.35);
        box-shadow: 0 4px 14px rgba(0,0,0,0.10);
        white-space: nowrap;
        opacity: 0;
        pointer-events: none;
        transition: opacity 0.2s;
        text-align: center;
        max-width: 180px;
        white-space: normal;
        line-height: 1.3;
      }
      #mascot-wrap:hover #mascot-tooltip {
        opacity: 1;
      }
      /* Modal overlay */
      #mascot-modal {
        display: none;
        position: fixed;
        inset: 0;
        z-index: 3000;
        background: rgba(0,0,0,0.45);
        align-items: center;
        justify-content: center;
        padding: 16px;
      }
      #mascot-modal.open { display: flex; }
      #mascot-modal-box {
        background: #fff;
        border-radius: 20px;
        padding: 32px 28px 24px;
        max-width: 320px;
        width: 100%;
        text-align: center;
        box-shadow: 0 16px 48px rgba(0,0,0,0.18);
        animation: mascot-enter 0.35s cubic-bezier(0.34,1.56,0.64,1) both;
        position: relative;
      }
      #mascot-modal-box img {
        width: 64px;
        margin-bottom: 12px;
      }
      #mascot-modal-box h3 {
        font-size: 1.1rem;
        font-weight: 700;
        color: #1b1b1b;
        margin-bottom: 8px;
      }
      #mascot-modal-box p {
        font-size: 0.92rem;
        color: #6b6b6b;
        margin-bottom: 16px;
        line-height: 1.5;
      }
      #mascot-modal-code {
        display: inline-block;
        background: linear-gradient(135deg, rgba(201,124,93,0.12), rgba(201,124,93,0.06));
        border: 2px dashed #C97C5D;
        color: #a85e3f;
        font-size: 1.4rem;
        font-weight: 800;
        letter-spacing: 3px;
        padding: 10px 22px;
        border-radius: 12px;
        margin-bottom: 20px;
      }
      #mascot-modal-close {
        background: #C97C5D;
        color: #fff;
        border: none;
        border-radius: 10px;
        padding: 10px 28px;
        font-weight: 600;
        font-size: 0.95rem;
        cursor: pointer;
        transition: background 0.2s;
      }
      #mascot-modal-close:hover { background: #a85e3f; }
      /* Smaller on mobile */
      @media(max-width:991px) {
        #mascot-img { width: 54px; height: 54px; }
        #mascot-wrap { bottom: 80px; right: 14px; }
      }
    </style>

    <!-- Mascot element -->
    <div id="mascot-wrap" role="button" aria-label="Cookie mascot — click for a discount">
      <div id="mascot-tooltip">Hi! Click me for a sweet in-store discount!</div>
      <img id="mascot-img" src="mascot/mascot.png" alt="Cookie mascot" />
    </div>

    <!-- Discount modal -->
    <div id="mascot-modal" role="dialog" aria-modal="true" aria-labelledby="mascot-modal-title">
      <div id="mascot-modal-box">
        <img src="mascot/mascot.png" alt="" aria-hidden="true" />
        <h3 id="mascot-modal-title">Your Sweet Discount!</h3>
        <p>Show this code at our store or mention it when ordering:</p>
        <div id="mascot-modal-code">COOKIE10</div>
        <br />
        <button id="mascot-modal-close">Got it, thanks!</button>
      </div>
    </div>

    <script>
      (function() {
        var wrap  = document.getElementById('mascot-wrap');
        var modal = document.getElementById('mascot-modal');
        var close = document.getElementById('mascot-modal-close');

        // Show mascot after 3 s
        setTimeout(function() {
          wrap.classList.add('mascot-visible');
        }, 3000);

        // Click mascot → open modal
        wrap.addEventListener('click', function() {
          modal.classList.add('open');
        });

        // Close modal
        function closeModal() { modal.classList.remove('open'); }
        close.addEventListener('click', closeModal);
        modal.addEventListener('click', function(e) {
          if (e.target === modal) closeModal();
        });
        document.addEventListener('keydown', function(e) {
          if (e.key === 'Escape') closeModal();
        });
      })();
    </script>
  </body>
</html>
